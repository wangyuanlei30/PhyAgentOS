{
  "_comment": "三机器人协同演示配置 (PiperGo2 + Franka + G1)",
  "_参考": "InternUtopia/internutopia/demo/test3_multi_robot_debug.py",
  "_说明": "Fleet模式: 3个hal_watchdog进程 + 1个PAOS agent共享ENVIRONMENT.md",

  "embodiments": {
